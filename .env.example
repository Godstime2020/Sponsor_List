# Copy to .env on the server and edit values.
# Generate a secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-ec2-public-hostname
# If you use HTTPS (recommended behind a load balancer or nginx):
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com
